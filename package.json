{
  "name": "@rnr/monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:docs": "turbo dev --filter=docs",
    "dev:showcase": "turbo dev --filter=@rnr/showcase --concurrency 32",
    "dev:showcase:android": "turbo dev:android --filter=@rnr/showcase --concurrency 32",
    "dev:showcase:web": "turbo dev:web --filter=@rnr/showcase --concurrency 32",
    "lint": "turbo lint",
    "test": "turbo test",
    "build": "turbo build",
    "build:showcase": "turbo build --filter=@rnr/showcase",
    "build:docs": "turbo build --filter=docs",
    "clean": "turbo clean && rm -rf .turbo node_modules"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/*",
        "expo-modules-*",
        "typescript"
      ],
      "allowedVersions": {
        "react": "19",
        "@types/react": "19"
      }
    },
    "overrides": {
      "react-native>@types/react": "^19.0.0",
      "lucide-react-native": "^0.511.0"
    }
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "trailingComma": "es5"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@9.1.4",
  "dependencies": {
    "@react-navigation/material-top-tabs": "^7.3.2",
    "@react-navigation/native": "^7.1.14",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "use-latest-callback": "^0.2.4"
  }
}
